# 브랜치 생성과 병합 실습 자동화 스크립트

# 환경 준비: Git 설치 확인
setup:
    @echo "=== 환경 확인 ==="
    @command -v git >/dev/null 2>&1 || { echo "오류: git이 설치되어 있지 않습니다."; exit 1; }
    @git --version
    @echo "Git이 정상적으로 설치되어 있습니다."

# 실행: I DO 시연 스크립트 실행
run:
    @echo "=== I DO 시연 실행 ==="
    @bash src/i-do/demo.sh

# 검증: 모든 단계 스크립트가 정상 동작하는지 확인
test:
    @echo "=== 테스트: I DO ==="
    @bash src/i-do/demo.sh > /dev/null 2>&1 && echo "  [PASS] I DO 시연 스크립트" || echo "  [FAIL] I DO 시연 스크립트"
    @echo "=== 테스트: WE DO ==="
    @bash src/we-do/practice.sh > /dev/null 2>&1 && echo "  [PASS] WE DO 실습 스크립트" || echo "  [FAIL] WE DO 실습 스크립트"
    @echo "=== 테스트: Solution ==="
    @bash solution/challenge.sh > /dev/null 2>&1 && echo "  [PASS] Solution 정답 스크립트" || echo "  [FAIL] Solution 정답 스크립트"
    @echo "=== 모든 테스트 완료 ==="

# 정리: 임시 파일 제거 (스크립트가 trap으로 자동 정리하므로 별도 작업 없음)
clean:
    @echo "=== 정리 ==="
    @echo "모든 스크립트는 /tmp에 임시 디렉토리를 생성하고 자동 정리합니다."
    @echo "수동 정리가 필요한 항목이 없습니다."
