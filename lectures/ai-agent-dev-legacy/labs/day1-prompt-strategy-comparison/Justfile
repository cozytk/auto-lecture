# 프롬프트 전략 비교 실습 명령어

# 기본 명령어
default:
    @just --list

# 의존성 설치
setup:
    pip install anthropic python-dotenv

# 수강생 템플릿 실행 (YOU DO)
run:
    python src/strategy_template.py

# Structured Output 템플릿 실행
run-structured:
    python src/structured_output.py

# 정답 코드 실행
solution:
    python solution/strategy_comparison.py

# Structured Output 정답 실행
solution-structured:
    python solution/structured_output.py

# 템플릿과 정답 순서대로 실행
compare:
    @echo "=== 수강생 코드 ==="
    python src/strategy_template.py
    @echo ""
    @echo "=== 정답 코드 ==="
    python solution/strategy_comparison.py

# 코드 정리
clean:
    find . -type f -name "*.pyc" -delete
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
