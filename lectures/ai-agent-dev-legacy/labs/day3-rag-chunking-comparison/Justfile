# Day 3 실습 2: RAG Chunking 비교

setup:
    pip install anthropic numpy pytest pytest-asyncio

check:
    python -c "import anthropic, numpy; print('OK')"
    python -c "import os; key=os.environ.get('ANTHROPIC_API_KEY'); print('API key:', 'set' if key else 'MISSING')"

demo-chunk:
    python src/demo_chunking.py

demo-retrieval:
    python src/demo_retrieval.py

demo-hallucination:
    python src/demo_hallucination.py

run:
    python src/rag_pipeline.py

run-custom:
    python src/rag_pipeline.py --doc "${RAG_DOC_PATH:-./sample_doc.md}"

test:
    pytest tests/ -v

clean:
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null; true
    find . -name "*.pyc" -delete 2>/dev/null; true
