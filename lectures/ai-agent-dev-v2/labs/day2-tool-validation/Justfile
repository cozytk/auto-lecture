
# Tool Validation 실습 Justfile

# 환경 설정
setup:
    pip install pydantic langchain-core

# WE DO 실행
we-do:
    python src/we_do_data_tools.py

# YOU DO 실행
you-do:
    python src/you_do_multi_source.py

# solution 실행
solution:
    python solution/multi_source_solution.py

# 전체 테스트
test:
    python -m pytest src/test_validation.py -v

# 정리
clean:
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
