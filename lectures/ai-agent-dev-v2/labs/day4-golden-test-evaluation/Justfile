# Day 4 Lab 1 — Golden Test Evaluation

# 환경 설정
setup:
    pip install -r src/requirements.txt
    @echo "환경 설정 완료. .env 파일에 OPENAI_API_KEY를 설정하세요."

# WE DO 실습 실행 (빈칸 채우기 버전)
run:
    python src/evaluate.py

# WE DO 결과 보고서 출력
report:
    python src/evaluate.py --report

# YOU DO 독립 과제 실행
you-do:
    python src/evaluate.py --my-tests my_golden_tests.json --report

# 정답 코드 실행 (시연 또는 비교용)
solution:
    python solution/evaluate.py

# 전체 테스트 실행 (solution 기준)
test:
    python solution/evaluate.py --report

# 정리
clean:
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
    @echo "정리 완료"
