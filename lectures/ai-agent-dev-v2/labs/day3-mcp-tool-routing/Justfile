# Day 3 실습 1: MCP Tool Routing

setup:
    pip install anthropic httpx pydantic pytest pytest-asyncio

check:
    python -c "import anthropic; print('OK')"
    python -c "import os; key=os.environ.get('ANTHROPIC_API_KEY'); print('API key:', 'set' if key else 'MISSING')"

demo-bad:
    python src/bad_tools.py

demo-good:
    python src/good_tools.py

run:
    python src/agent.py

test:
    pytest tests/ -v

clean:
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null; true
    find . -name "*.pyc" -delete 2>/dev/null; true
