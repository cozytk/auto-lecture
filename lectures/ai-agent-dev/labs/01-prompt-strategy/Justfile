# 실습 01: 프롬프트 전략 비교 자동화 스크립트

# 환경 준비: 의존성 설치
setup:
    pip install openai

# I DO 시연 코드 실행
run-i-do:
    python src/i-do/classify.py

# WE DO 함께 실습 코드 실행
run-we-do:
    python src/we-do/classify.py

# YOU DO 과제 코드 실행
run:
    python src/you-do/classify.py

# 정답 코드 실행
run-solution:
    python solution/classify.py

# 검증: 과제 코드가 5개 문의를 모두 분류하는지 확인
test:
    @echo "=== YOU DO 결과 검증 ==="
    python -c "
import subprocess, sys
result = subprocess.run([sys.executable, 'src/you-do/classify.py'], capture_output=True, text=True)
print(result.stdout)
if result.returncode != 0:
    print('오류:', result.stderr)
    sys.exit(1)
lines = [l for l in result.stdout.split('\n') if l.strip() and not l.startswith('===') and not l.startswith('-') and not l.startswith('1.') and not l.startswith('2.') and not l.startswith('3.')]
if len(lines) >= 5:
    print('검증 통과: 5개 문의 모두 처리됨')
else:
    print('검증 실패: 결과 행이 부족합니다')
    sys.exit(1)
"

# 정리: 캐시 파일 제거
clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
