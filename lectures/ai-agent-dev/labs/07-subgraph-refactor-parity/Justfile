# 실습 07: Subgraph Refactor Parity 자동화 스크립트

default:
    @just --list

setup:
    pip install langgraph

run-i-do:
    python src/i-do/refactor_parity.py

run-we-do:
    python src/we-do/refactor_parity.py

run:
    python src/you-do/refactor_parity.py

run-solution:
    python solution/refactor_parity.py

test:
    @python -c "import pathlib, sys; sys.path.insert(0, 'src/you-do'); import refactor_parity as lab; source = pathlib.Path('src/you-do/refactor_parity.py').read_text(); print('[PASS]' if 'build_monolith' in source else '[FAIL]', 'build_monolith 존재 여부'); print('[PASS]' if 'build_refactored' in source else '[FAIL]', 'build_refactored 존재 여부'); print('[PASS]' if 'check_parity' in source else '[FAIL]', 'check_parity 존재 여부'); sample_a = {'report': 'ok', 'insights': ['a'], 'raw_data': ['x', 'y']}; sample_b = {'report': 'ok', 'insights': ['a'], 'raw_data': ['x', 'y']}; sample_c = {'report': 'diff', 'insights': ['a'], 'raw_data': ['x', 'y']}; print('[PASS]' if lab.check_parity(sample_a, sample_b) else '[FAIL]', 'parity true case'); print('[PASS]' if not lab.check_parity(sample_a, sample_c) else '[FAIL]', 'parity false case'); print('[WARN] YOU DO 파일에 TODO가 남아 있습니다' if 'TODO' in source else '[PASS] YOU DO 파일에 TODO 없음')"

verify-solution:
    python solution/refactor_parity.py

clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
