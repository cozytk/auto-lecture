# 실습 02: Structured Output 자동화 스크립트

# 환경 준비: 의존성 설치
setup:
    pip install openai pydantic

# I DO 시연 코드 실행
run-i-do:
    python src/i-do/ticket_classifier.py

# WE DO 함께 실습 코드 실행
run-we-do:
    python src/we-do/agent_action.py

# YOU DO 과제 코드 실행
run:
    python src/you-do/agent_action.py

# 정답 코드 실행
run-solution:
    python solution/agent_action.py

# 검증: 5개 시나리오 처리 및 환불 규칙 확인
test:
    @echo "=== YOU DO 결과 검증 ==="
    python -c "
import subprocess, sys
result = subprocess.run([sys.executable, 'src/you-do/agent_action.py'], capture_output=True, text=True)
print(result.stdout)
if result.returncode != 0:
    print('오류:', result.stderr)
    sys.exit(1)
output = result.stdout
if '환불' in output and ('escalate' in output.lower() or '에스컬레이션' in output):
    print('검증 통과: 환불 → escalate 규칙이 동작합니다')
else:
    print('검증 주의: 출력에서 escalate 행동을 확인하세요')
"

# 정리: 캐시 파일 제거
clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
