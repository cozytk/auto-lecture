# 실습 03: MCP Tool 기반 Agent 구현 (Function Calling)

export OPENROUTER_API_KEY := env_var_or_default("OPENROUTER_API_KEY", "")
export MODEL := env_var_or_default("MODEL", "moonshotai/kimi-k2")

# 기본: 도움말 출력
default:
    @just --list

# 환경 설정
setup:
    pip install openai pydantic

# I DO: 시연 코드 실행
run-i-do:
    python src/i-do/agent.py

# WE DO: 함께 실습 실행
run-we-do:
    python src/we-do/agent.py

# YOU DO: 학생 과제 실행
run:
    python src/you-do/agent.py

# 정답 확인
run-solution:
    python solution/agent.py

# 테스트 실행
test:
    @echo "=== Tool 정의 검증 ==="
    @python -c "
import sys
sys.path.insert(0, 'src/you-do')
import agent
# Tool description 길이 검증
for tool in agent.tools:
    name = tool['function']['name']
    desc = tool['function']['description']
    length = len(desc)
    status = 'PASS' if length >= 30 else 'FAIL'
    print(f'[{status}] {name}: description {length}자')
    if length < 30:
        print(f'  -> 30자 이상 작성 필요 (현재: {desc!r})')

# required 파라미터 검증
for tool in agent.tools:
    name = tool['function']['name']
    required = tool['function']['parameters'].get('required', [])
    props = tool['function']['parameters'].get('properties', {})
    if required:
        print(f'[PASS] {name}: required={required}')
    else:
        print(f'[WARN] {name}: required 파라미터 없음')
print()
print('Tool 정의 검증 완료.')
"
    @echo ""
    @echo "=== Agent 루프 검증 (Tool 호출 불필요한 질문) ==="
    @python -c "
import sys, inspect
sys.path.insert(0, 'src/you-do')
import agent
src = inspect.getsource(agent.run_agent)
if 'while True' in src or 'while not' in src:
    print('[PASS] Agent 루프 구현됨 (while 루프 존재)')
else:
    print('[FAIL] Agent 루프 미구현: while 루프를 추가하세요')
if 'tool_calls' in src:
    print('[PASS] tool_calls 처리 로직 존재')
else:
    print('[FAIL] tool_calls 처리 로직 없음')
if 'role.*tool' in src or '\"tool\"' in src or \"'tool'\" in src:
    print('[PASS] tool 메시지 추가 로직 존재')
else:
    print('[FAIL] tool 역할 메시지 추가 로직 없음')
"
    @echo ""
    @echo "주의: 실제 API 호출 테스트는 OPENROUTER_API_KEY 필요"

# 초기화
clean:
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
    @echo "정리 완료"
