# studylog 실습 Justfile
# 사용법: just <recipe>

default:
    @just --list

setup:
    @echo "=== studylog 환경 설정 ==="
    @echo "Python 표준 라이브러리만 사용 — 별도 설치 불필요"
    @python3 --version
    @echo "설정 완료!"

run:
    @echo "=== studylog 사용법 ==="
    @echo "세션 시작:  python3 src/studylog.py start '주제' --tags '태그1,태그2'"
    @echo "세션 종료:  python3 src/studylog.py stop --notes '메모'"
    @echo "현재 세션:  python3 src/studylog.py current"
    @echo "목록 조회:  python3 src/studylog.py list"
    @echo "통계 보기:  python3 src/studylog.py stats"
    @echo "내보내기:   python3 src/studylog.py export --output data.json"

test:
    @echo "=== 테스트 실행 ==="
    cd src && python3 -m unittest test_studylog -v

test-short:
    cd src && python3 -m unittest test_studylog -q

seed:
    @echo "=== 샘플 데이터 생성 ==="
    @mkdir -p ~/.studylog
    @python3 -c "\
    import json, pathlib; \
    data = {'version': 2, 'sessions': { \
      'a1b2c3d4': {'id': 'a1b2c3d4', 'topic': 'Python 기초', 'tags': ['python'], 'started_at': '2024-03-15 09:00', 'ended_at': '2024-03-15 09:45', 'duration_minutes': 45, 'notes': '변수와 함수', 'status': 'completed'}, \
      'e5f6g7h8': {'id': 'e5f6g7h8', 'topic': 'JavaScript', 'tags': ['js', 'web'], 'started_at': '2024-03-16 10:00', 'ended_at': '2024-03-16 11:00', 'duration_minutes': 60, 'notes': 'DOM 조작', 'status': 'completed'}, \
      'i9j0k1l2': {'id': 'i9j0k1l2', 'topic': 'Python 심화', 'tags': ['python'], 'started_at': '2024-03-17 14:00', 'ended_at': '2024-03-17 15:30', 'duration_minutes': 90, 'notes': '클래스와 상속', 'status': 'completed'}, \
    }}; \
    p = pathlib.Path.home() / '.studylog'; p.mkdir(exist_ok=True); \
    (p / 'data.json').write_text(json.dumps(data, indent=2, ensure_ascii=False)); \
    print('샘플 3개 세션 생성 완료')"
    cd src && python3 studylog.py list

clean:
    @echo "=== 데이터 초기화 ==="
    @rm -f ~/.studylog/data.json && echo "데이터 파일 삭제 완료" || echo "삭제할 파일 없음"
    @find src -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
    @find src -name "*.pyc" -delete 2>/dev/null || true
    @echo "정리 완료"
