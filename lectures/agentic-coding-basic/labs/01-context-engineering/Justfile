# 컨텍스트 엔지니어링 챌린지 실습 Justfile

# 기본 타겟
default:
    @just --list

# ── 환경 준비 ─────────────────────────────────────────────────

# 환경 확인 (Python 버전, 필요 모듈 체크)
setup:
    @echo "=== 환경 확인 ==="
    python3 --version
    python3 -c "import http.server, json, uuid, dataclasses; print('필수 모듈 OK')"
    @echo "환경 준비 완료"

# ── 테스트 ────────────────────────────────────────────────────

# 기본 src/ 코드 테스트
test:
    @echo "=== src/ 테스트 실행 ==="
    cd src && python3 test_api.py -v

# Round 1 테스트 (AGENTS.md 없음)
test-r1:
    @echo "=== Round 1 테스트 (AGENTS.md 없음) ==="
    cd round1/src && python3 test_api.py -v

# Round 2 테스트 (기본 AGENTS.md 있음)
test-r2:
    @echo "=== Round 2 테스트 (기본 AGENTS.md 있음) ==="
    cd round2/src && python3 test_api.py -v

# Round 3 테스트 (풍부한 컨텍스트)
test-r3:
    @echo "=== Round 3 테스트 (풍부한 컨텍스트) ==="
    cd round3/src && python3 test_api.py -v

# 전체 테스트 (모든 라운드)
test-all:
    @echo "=== 전체 테스트 ==="
    just test
    just test-r1
    just test-r2
    just test-r3
    @echo "=== 모든 테스트 완료 ==="

# ── 서버 실행 ─────────────────────────────────────────────────

# 기본 src/ 서버 실행 (포트 8000)
serve:
    @echo "북마크 API 서버 시작: http://localhost:8000"
    cd src && python3 app.py

# Round 1 서버 실행 (포트 8001)
serve-r1:
    @echo "Round 1 서버: http://localhost:8001"
    cd round1/src && python3 app.py 8001

# Round 2 서버 실행 (포트 8002)
serve-r2:
    @echo "Round 2 서버: http://localhost:8002"
    cd round2/src && python3 app.py 8002

# Round 3 서버 실행 (포트 8003)
serve-r3:
    @echo "Round 3 서버: http://localhost:8003"
    cd round3/src && python3 app.py 8003

# ── 정리 ──────────────────────────────────────────────────────

# 생성된 DB 파일 및 캐시 정리
clean:
    @echo "=== 정리 ==="
    find . -name "*.json" -not -path "*/artifacts/*" -delete 2>/dev/null || true
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
    find . -name "*.pyc" -delete 2>/dev/null || true
    @echo "정리 완료"

# ── 카테고리 기능 데모 (서버 시작 → curl 테스트 → 종료) ──────

# Round 1 카테고리 데모
demo-r1:
    #!/usr/bin/env bash
    set -e
    echo "=== Round 1 카테고리 데모 ==="
    cd round1/src
    python3 app.py 8001 &
    SERVER_PID=$!
    sleep 1
    echo "--- 북마크 생성 (category: docs) ---"
    curl -s -X POST http://localhost:8001/bookmarks \
        -H "Content-Type: application/json" \
        -d '{"title":"파이썬","url":"https://python.org","category":"docs"}' | python3 -m json.tool || true
    echo "--- 카테고리 필터링 ---"
    curl -s "http://localhost:8001/bookmarks?category=docs" | python3 -m json.tool || true
    kill $SERVER_PID 2>/dev/null || true
    echo "=== 데모 완료 ==="

# Round 2 카테고리 데모
demo-r2:
    #!/usr/bin/env bash
    set -e
    echo "=== Round 2 카테고리 데모 ==="
    cd round2/src
    python3 app.py 8002 &
    SERVER_PID=$!
    sleep 1
    echo "--- 북마크 생성 (category: docs) ---"
    curl -s -X POST http://localhost:8002/bookmarks \
        -H "Content-Type: application/json" \
        -d '{"title":"파이썬","url":"https://python.org","category":"docs"}' | python3 -m json.tool || true
    echo "--- 카테고리 필터링 ---"
    curl -s "http://localhost:8002/bookmarks?category=docs" | python3 -m json.tool || true
    kill $SERVER_PID 2>/dev/null || true
    echo "=== 데모 완료 ==="

# Round 3 카테고리 데모
demo-r3:
    #!/usr/bin/env bash
    set -e
    echo "=== Round 3 카테고리 데모 ==="
    cd round3/src
    python3 app.py 8003 &
    SERVER_PID=$!
    sleep 1
    echo "--- 북마크 생성 (category: docs) ---"
    curl -s -X POST http://localhost:8003/bookmarks \
        -H "Content-Type: application/json" \
        -d '{"title":"파이썬","url":"https://python.org","category":"docs"}' | python3 -m json.tool || true
    echo "--- 카테고리 필터링 ---"
    curl -s "http://localhost:8003/bookmarks?category=docs" | python3 -m json.tool || true
    kill $SERVER_PID 2>/dev/null || true
    echo "=== 데모 완료 ==="

# ── curl 예시 (서버가 이미 실행 중일 때) ──────────────────────

# 북마크 생성 예시 (서버가 실행 중이어야 함)
demo-create PORT="8000":
    @echo "=== 북마크 생성 ==="
    curl -s -X POST http://localhost:{{PORT}}/bookmarks \
        -H "Content-Type: application/json" \
        -d '{"title":"Python 공식 문서","url":"https://docs.python.org","description":"파이썬 레퍼런스"}' | python3 -m json.tool

# 북마크 목록 조회 예시
demo-list PORT="8000":
    @echo "=== 북마크 목록 ==="
    curl -s http://localhost:{{PORT}}/bookmarks | python3 -m json.tool

# 헬스 체크
demo-health PORT="8000":
    curl -s http://localhost:{{PORT}}/health | python3 -m json.tool
