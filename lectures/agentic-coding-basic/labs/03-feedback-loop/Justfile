# Lab 03: 자기 수정 피드백 루프 구축
# 사용법: just <recipe>

SRC_DIR := "src"
SOLUTION_DIR := "solution"

# 기본 레시피: 도움말 출력
default:
    @just --list

# 환경 준비 (Python 버전 확인)
setup:
    @echo "=== 환경 확인 ==="
    @python3 --version
    @echo "Python 표준 라이브러리만 사용합니다. 별도 패키지 설치 불필요."
    @echo ""
    @echo "실습 디렉토리: {{SRC_DIR}}/"
    @echo "솔루션 디렉토리: {{SOLUTION_DIR}}/"
    @echo ""
    @echo "시작하려면: just test"

# 버그 있는 코드로 테스트 실행 (3개 실패 예상)
test:
    @echo "=== 테스트 실행 (버그 있는 코드) ==="
    @echo "3개 테스트가 실패해야 정상입니다."
    @echo ""
    cd {{SRC_DIR}} && python -m unittest test_vocab -v 2>&1; true

# 솔루션 코드로 테스트 실행 (전부 통과 예상)
test-solution:
    @echo "=== 테스트 실행 (솔루션 코드) ==="
    @echo "모든 테스트가 통과해야 합니다."
    @echo ""
    cd {{SOLUTION_DIR}} && python -m unittest test_vocab -v

# 단어장 앱 실행 (대화형)
run:
    @echo "단어장 앱을 실행합니다."
    @echo "사용법: add <영어> <한국어> | list | delete <영어> | stats"
    @echo ""
    cd {{SRC_DIR}} && python vocab.py

# 단어장에 샘플 단어 추가 (데모용)
demo-add:
    @echo "=== 샘플 단어 추가 ==="
    cd {{SRC_DIR}} && python vocab.py add apple 사과
    cd {{SRC_DIR}} && python vocab.py add banana 바나나
    cd {{SRC_DIR}} && python vocab.py add computer 컴퓨터
    cd {{SRC_DIR}} && python vocab.py add keyboard 키보드
    cd {{SRC_DIR}} && python vocab.py add monitor 모니터
    @echo ""
    cd {{SRC_DIR}} && python vocab.py list

# 자동 수정 루프 실행 (opencode 필요)
auto-fix:
    @echo "=== 자동 수정 루프 시작 ==="
    @echo "opencode가 설치되어 있어야 합니다."
    @echo ""
    cd {{SRC_DIR}} && bash auto_fix.sh

# 솔루션의 자동 수정 루프 실행
auto-fix-solution:
    @echo "=== 솔루션 자동 수정 루프 ==="
    cd {{SOLUTION_DIR}} && bash auto_fix.sh

# 생성된 데이터 파일 정리
clean:
    @echo "=== 데이터 파일 정리 ==="
    -rm -f {{SRC_DIR}}/vocab_data.json
    -rm -f {{SRC_DIR}}/stats_data.json
    -rm -f {{SRC_DIR}}/auto_fix_log.txt
    -rm -f {{SRC_DIR}}/test_output.txt
    -rm -f {{SOLUTION_DIR}}/vocab_data.json
    -rm -f {{SOLUTION_DIR}}/stats_data.json
    -rm -f {{SOLUTION_DIR}}/auto_fix_log.txt
    -rm -f {{SOLUTION_DIR}}/test_output.txt
    @echo "정리 완료!"

# 실패하는 테스트만 확인
test-failures:
    @echo "=== 실패하는 테스트 확인 ==="
    cd {{SRC_DIR}} && python -m unittest test_vocab.TestScoreCalculation.test_score_calculation_with_string_values test_vocab.TestCaseInsensitiveAnswer.test_case_insensitive_answer test_vocab.TestDeleteCleanStats.test_delete_cleans_stats -v 2>&1; true

# 버그 힌트 출력
hints:
    @echo "=== 버그 힌트 ==="
    @echo ""
    @echo "버그 1 (stats.py):"
    @echo "  calculate_score() 함수에서 correct 인자가 문자열일 때 처리하지 못합니다."
    @echo "  힌트: int() 변환을 추가해보세요."
    @echo ""
    @echo "버그 2 (quiz.py):"
    @echo "  check_answer() 함수가 대소문자를 구분하여 비교합니다."
    @echo "  힌트: .lower() 메서드를 사용해보세요."
    @echo ""
    @echo "버그 3 (vocab.py):"
    @echo "  delete_word() 함수가 stats_data.json에서 해당 단어를 삭제하지 않습니다."
    @echo "  힌트: load_stats(), del stats[english], save_stats()를 추가해보세요."
